# EmpValue-AI 环境变量示例
# 复制为 .env 并填入实际值

# 应用配置
APP_NAME=EmpValue-AI
DEBUG=false

# 数据库（默认 SQLite，生产环境建议 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./empvalue_ai.db

# 模型档位：auto / L0 / L1 / L2 / L3
MODEL_TIER=auto

# 通用云端模型（OpenAI 兼容接口）
# 适合 DeepSeek / 阿里云百炼 / 硅基流动 等
CLOUD_API_KEY=your-cloud-api-key
CLOUD_BASE_URL=https://api.openai.com/v1
CLOUD_MODEL=gpt-4o-mini

# 兼容旧版 OpenAI 命名（未设置 cloud_* 时兜底使用）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 本地模型（LM Studio / Ollama）
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_API_KEY=lm-studio
LOCAL_MODEL_L1=qwen2.5-0.5b-instruct
LOCAL_MODEL_L2=qwen2.5-7b-instruct
LOCAL_MODEL_L3=qwen2.5-14b-instruct

# Embedding 配置（OpenAI 兼容接口）
# 使用云端 embedding 服务时，填 base_url + api_key；
# 使用本地 embedding 时，指向 LM Studio / Ollama / Xinference 等兼容接口。
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 向量库存储目录
VECTOR_STORE_DIR=./chroma_db

# 附件存储目录（路径遍历防护白名单根目录，附件文件仅允许在此目录内读取）
ATTACHMENT_DIR=./attachments

# 推理参数
TEMPERATURE=0.1
MAX_TOKENS=4096

# JWT 认证配置（生产环境必须修改 JWT_SECRET_KEY）
JWT_SECRET_KEY=change-this-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 演示模式：true 时允许通过 x-user-role / x-user-id header 伪造身份（仅开发/测试用）
# 生产环境必须设为 false
AUTH_DEMO_MODE=false

# Langfuse 可观测性（可选）
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
